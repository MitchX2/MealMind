<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MealMind.Views.Controls.IngredientListView"
             x:Name="Root">

    <!-- Reusable ingredient list control.
     Displays ingredients and measures in a themed card, with optional title + empty state support. -->

    <Border StrokeThickness="1"
            Stroke="{DynamicResource BorderColor}"
            BackgroundColor="{DynamicResource CardBackground}"
            StrokeShape="RoundRectangle 18"
            Padding="12"
            Margin="0,4">

        <Border.Shadow>
            <Shadow Offset="0,4" Radius="8" Opacity="0.18" />
        </Border.Shadow>

        <VerticalStackLayout Spacing="10">

            <!-- Optional title provided by the parent page (Title + ShowTitle bindables) -->

            <Label Text="{Binding Title, Source ={x:Reference Root}}"
                   IsVisible="{Binding ShowTitle ,Source ={x:Reference Root}}"
                   TextColor="{DynamicResource PrimaryText}"
                   FontAttributes="Bold"
                   FontSize="16" />

            <!-- Empty state shown when there are no ingredients (IsEmpty / IsNotEmpty computed in code-behind) -->
            <Label Text="{Binding EmptyText ,Source ={x:Reference Root}}"
                   IsVisible="{Binding IsEmpty ,Source ={x:Reference Root}}"
                   TextColor="{DynamicResource SecondaryText}"
                   FontSize="13" />

            <!-- Ingredients list bound via x:Reference Root so the control can be reused with any parent ViewModel -->
            <CollectionView ItemsSource="{Binding Items ,Source={x:Reference Root}}"
                            IsVisible="{Binding IsNotEmpty ,Source={x:Reference Root}}"
                            SelectionMode="None">

                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <!-- Two-column row: ingredient name (left) and measure text (right) -->
                        <Grid ColumnDefinitions="*,Auto"
                              RowDefinitions="Auto"
                              ColumnSpacing="12"
                              Padding="6,4">

                            <Label Grid.Column="0"
                                   Text="{Binding Name}"
                                   TextColor="{DynamicResource PrimaryText}"
                                   FontSize="14"
                                   LineBreakMode="TailTruncation" />

                            <Label Grid.Column="1"
                                   Text="{Binding MeasureRaw}"
                                   TextColor="{DynamicResource SecondaryText}"
                                   FontSize="13"
                                   HorizontalTextAlignment="End" />

                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </VerticalStackLayout>
    </Border>
</ContentView>
