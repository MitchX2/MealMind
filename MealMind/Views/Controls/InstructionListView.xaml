<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MealMind.Views.Controls.InstructionListView"
             x:Name="Root">

    <!-- Reusable instruction list control.
     Displays numbered steps with optional tick checkboxes and a built-in empty state. -->


    <Border StrokeThickness="1"
            Stroke="{DynamicResource BorderColor}"
            BackgroundColor="{DynamicResource CardBackground}"
            StrokeShape="RoundRectangle 18"
            Padding="12"
            Margin="0,4">

        <!-- Card container styled using DynamicResource so theme changes apply automatically -->
        <Border.Shadow>
            <Shadow Offset="0,4" Radius="8" Opacity="0.18" />
        </Border.Shadow>

        <VerticalStackLayout Spacing="10">

            <!-- Optional title provided by the parent page (Title + ShowTitle bindables) -->
            <Label Text="{Binding Title , Source={x:Reference Root}}"
                   IsVisible="{Binding ShowTitle , Source={x:Reference Root}}"
                   TextColor="{DynamicResource PrimaryText}"
                   FontAttributes="Bold"
                   FontSize="16" />

            <!-- Empty state if null-->
            <Label Text="{Binding EmptyText, Source={x:Reference Root} }"
                   IsVisible="{Binding IsEmpty, Source={x:Reference Root} }"
                   TextColor="{DynamicResource SecondaryText}"
                   FontSize="13" />

            <!-- Steps list bound via x:Reference Root so the control is self-contained and reusable -->
            <CollectionView ItemsSource="{Binding Items, Source={x:Reference Root}}"
                IsVisible="{Binding IsNotEmpty, Source={x:Reference Root}}"
                SelectionMode="None">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="Auto,Auto,*"
                            ColumnSpacing="10"
                            Padding="6,6">

                            <!-- Optional checkbox: visibility controlled by EffectiveShowCheckbox; state binds to InstructionStep.IsDone -->
                            <CheckBox Grid.Column="0"
                            IsVisible="{Binding EffectiveShowCheckbox, Source={x:Reference Root}}"
                            IsChecked="{Binding IsDone, Mode=TwoWay}" />

                        <Label Grid.Column="1"
                            Text="{Binding Number}"
                            TextColor="{DynamicResource SecondaryText}"
                            FontAttributes="Bold" />

                        <Label Grid.Column="2"
                            Text="{Binding Text}"
                            TextColor="{DynamicResource PrimaryText}"
                            FontSize="14"
                            LineBreakMode="WordWrap" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </Border>
</ContentView>
