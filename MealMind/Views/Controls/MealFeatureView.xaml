<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MealMind.Views.Controls.MealFeatureView"
             x:Name="Root">


    <!-- Card -->
    <Border StrokeThickness="1"
            Stroke="{DynamicResource BorderColor}"
            BackgroundColor="{DynamicResource CardBackground}"
            StrokeShape="RoundRectangle 18"
            Padding="10"
            Margin="0,4">

        <Border.Shadow>
            <Shadow Offset="0,4" Radius="8" Opacity="0.18" />
        </Border.Shadow>

        <!-- Single child of Border -->
        <Grid RowDefinitions="Auto,Auto"
              ColumnDefinitions="Auto,*"
              RowSpacing="8"
              ColumnSpacing="12">

            <!-- Rounded image with tap -->
            <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 14"
                    WidthRequest="110"
                    HeightRequest="110">
                <Image Aspect="AspectFill"
                       Source="{Binding MealImage}"
                       WidthRequest="110"
                       HeightRequest="110" />
                <Border.GestureRecognizers>
                    <TapGestureRecognizer
                        Command="{Binding TapCommand}"
                        CommandParameter="{Binding TapCommandParameter}" />
                </Border.GestureRecognizers>
            </Border>

            <!-- Title -->
            <Label Grid.Row="0" Grid.Column="1"
                   Text="{Binding Title}"
                   TextColor="{DynamicResource TextPrimary}"
                   FontAttributes="Bold"
                   FontSize="20"
                   LineBreakMode="TailTruncation" />

            <!-- Ingredients preview -->
            <Label Grid.Row="1" Grid.Column="1"
                   Text="{Binding IngredientsPreview}"
                   TextColor="{DynamicResource TextSecondary}"
                   FontSize="13"
                   LineBreakMode="WordWrap"
                   MaxLines="3" />

            <!-- Nav buttons : transparent overlays -->
            <Grid Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Grid.ColumnSpan="2"
                  IsVisible="{Binding ShowNavButtons}">
                <Grid ColumnDefinitions="*,*">
                    <Button Grid.Column="0"
                            BackgroundColor="{DynamicResource accElementBackground}"
                            Command="{Binding LeftCommand}"
                            Opacity="0.01"
                            AutomationProperties.Name="Previous meal" />
                    
                    <!-- accElement allows for an accesability theme to make nav buttons visible-->
                    <Button Grid.Column="1"
                            BackgroundColor="{DynamicResource accElementBackground}"
                            Command="{Binding RightCommand}"
                            Opacity="0.01"
                            AutomationProperties.Name="Next meal" />
                </Grid>
            </Grid>
            
        <!-- grid inside the first border to allow the image to be set in another border-->
        </Grid>
    </Border>
</ContentView>
