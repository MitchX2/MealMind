<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MealMind.MainPage"
             xmlns:controls="clr-namespace:MealMind.Views.Controls" >

    <!-- Putting the page in a grid to ensure the TitleBanner and NavBer 
            Stay where theyre suppose to be 
            Auto used to esure they take up space difined in the class-->
    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Banner at top roe 0-->
        <controls:TitleBannerView Grid.Row="0" />

        <!-- Main content  in the center-->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="15">
                <!-- Test display-->
                <Label Text="Display Label for the MainPage test"
                       FontSize="20"/>
                
                <!-- Put MealFeatureView and search content here -->
                
            
            </VerticalStackLayout>
        </ScrollView>

        <!-- Nav bar fixed at bottom  row 3-->
        <controls:NavBarView Grid.Row="2" />

    </Grid>


</ContentPage>

    