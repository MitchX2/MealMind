<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                     xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                     x:Class="MealMind.Resources.Styles.ColorsDark">
    <!-- Backgrounds -->
    <Color x:Key="AppBackground">#121212</Color>
    <Color x:Key="SurfaceBackground">#1E1E1E</Color>

    <!-- Text -->
    <Color x:Key="PrimaryText">#F3F4F6</Color>
    <Color x:Key="SecondaryText">#9CA3AF</Color>
    <Color x:Key="MutedText">#6B7280</Color>

    <!-- Accent stays recognisable -->
    <Color x:Key="Accent">#F09A5A</Color>
    <Color x:Key="AccentSoft">#3A2A1F</Color>

    <!-- UI -->
    <Color x:Key="BorderColor">#2A2A2A</Color>
    <Color x:Key="DividerColor">#3A3A3A</Color>

    <!-- Buttons -->
    <Color x:Key="ButtonPrimaryBackground">#F09A5A</Color>
    <Color x:Key="ButtonPrimaryText">#121212</Color>

    <Color x:Key="ButtonSecondaryBackground">#1E1E1E</Color>
    <Color x:Key="ButtonSecondaryText">#F09A5A</Color>

</ResourceDictionary>