<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    x:Class="MealMind.Resources.Styles.ColorsDark">

    <!-- ========================= -->
    <!-- Core backgrounds -->
    <!-- ========================= -->

    <!-- App background: deep navy -->
    <Color x:Key="AppBackground">#132440</Color>

    <!-- Surfaces / cards -->
    <Color x:Key="SurfaceBackground">#16476A</Color>
    <Color x:Key="CardBackground">#16476A</Color>


    <!-- ========================= -->
    <!-- Text -->
    <!-- ========================= -->

    <!-- Primary text: very light neutral -->
    <Color x:Key="PrimaryText">#F2F4F7</Color>

    <!-- Secondary text -->
    <Color x:Key="SecondaryText">#C9D3DC</Color>

    <!-- Muted text -->
    <Color x:Key="MutedText">#9FB0BF</Color>


    <!-- ========================= -->
    <!-- Accent / brand -->
    <!-- ========================= -->

    <!-- Primary accent (soft pink) -->
    <Color x:Key="Accent">#FDB5CE</Color>

    <!-- Soft accent for highlights -->
    <Color x:Key="AccentSoft">#3B9797</Color>


    <!-- ========================= -->
    <!-- UI elements -->
    <!-- ========================= -->

    <!-- Borders & dividers -->
    <Color x:Key="BorderColor">#2A5A7A</Color>
    <Color x:Key="DividerColor">#2F6A7A</Color>


    <!-- ========================= -->
    <!-- Buttons -->
    <!-- ========================= -->

    <!-- Primary button -->
    <Color x:Key="ButtonPrimaryBackground">#FDB5CE</Color>
    <Color x:Key="ButtonPrimaryText">#132440</Color>

    <!-- Secondary button -->
    <Color x:Key="ButtonSecondaryBackground">#16476A</Color>
    <Color x:Key="ButtonSecondaryText">#FDB5CE</Color>


    <!-- ========================= -->
    <!-- States -->
    <!-- ========================= -->

    <Color x:Key="DisabledBackground">#1F3A50</Color>
    <Color x:Key="DisabledText">#8FA1B2</Color>


    <!-- ========================= -->
    <!-- Accessibility -->
    <!-- ========================= -->

    <!-- High-contrast touch overlays -->
    <Color x:Key="accElementBackground">#33FFFFFF</Color>


    <!-- ========================= -->
    <!-- Debug flag -->
    <!-- ========================= -->

    <x:String x:Key="__ColorsDarkLoaded">YES</x:String>

</ResourceDictionary>