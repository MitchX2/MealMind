<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    x:Class="MealMind.Resources.Styles.ColorsLight">

    <!-- ========================= -->
    <!-- Core backgrounds -->
    <!-- ========================= -->

    <!-- App background: warm cream -->
    <Color x:Key="AppBackground">#F6F0D7</Color>

    <!-- Surfaces / cards -->
    <Color x:Key="SurfaceBackground">#FFFFFF</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>


    <!-- ========================= -->
    <!-- Text -->
    <!-- ========================= -->

    <!-- Primary text: deep olive -->
    <Color x:Key="PrimaryText">#2F3A23</Color>

    <!-- Secondary text -->
    <Color x:Key="SecondaryText">#5E6A4D</Color>

    <!-- Muted text -->
    <Color x:Key="MutedText">#7E8A6A</Color>


    <!-- ========================= -->
    <!-- Accent / brand -->
    <!-- ========================= -->

    <!-- Primary accent -->
    <Color x:Key="Accent">#89986D</Color>

    <!-- Soft accent for highlights -->
    <Color x:Key="AccentSoft">#C5D89D</Color>


    <!-- ========================= -->
    <!-- UI elements -->
    <!-- ========================= -->

    <!-- Borders & dividers -->
    <Color x:Key="BorderColor">#D6D1B8</Color>
    <Color x:Key="DividerColor">#E1DBC2</Color>


    <!-- ========================= -->
    <!-- Buttons -->
    <!-- ========================= -->

    <!-- Primary button -->
    <Color x:Key="ButtonPrimaryBackground">#89986D</Color>
    <Color x:Key="ButtonPrimaryText">#FFFFFF</Color>

    <!-- Secondary button -->
    <Color x:Key="ButtonSecondaryBackground">#FFFFFF</Color>
    <Color x:Key="ButtonSecondaryText">#89986D</Color>


    <!-- ========================= -->
    <!-- States -->
    <!-- ========================= -->

    <Color x:Key="DisabledBackground">#E6E1C9</Color>
    <Color x:Key="DisabledText">#9CAB84</Color>


    <!-- ========================= -->
    <!-- Accessibility -->
    <!-- ========================= -->

    <!-- High-contrast touch overlays -->
    <Color x:Key="accElementBackground">#33000000</Color>


    <!-- ========================= -->
    <!-- Debug flag -->
    <!-- ========================= -->

    <x:String x:Key="__ColorsLightLoaded">YES</x:String>

</ResourceDictionary>