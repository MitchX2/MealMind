<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    x:Class="MealMind.Resources.Styles.ColorsDefault">

    <!-- ========================= -->
    <!-- Core backgrounds -->
    <!-- ========================= -->

    <!-- App background: very light neutral -->
    <Color x:Key="AppBackground">#F5F5F5</Color>

    <!-- Surfaces / cards sit slightly above app background -->
    <Color x:Key="SurfaceBackground">#FFFFFF</Color>

    <!-- Cards -->
    <Color x:Key="CardBackground">#FFFFFF</Color>


    <!-- ========================= -->
    <!-- Text -->
    <!-- ========================= -->

    <!-- Primary text: deep navy -->
    <Color x:Key="PrimaryText">#001F3D</Color>

    <!-- Secondary text: softened navy -->
    <Color x:Key="SecondaryText">#4B5F73</Color>

    <!-- Muted / helper text -->
    <Color x:Key="MutedText">#8A94A3</Color>


    <!-- ========================= -->
    <!-- Accent / brand -->
    <!-- ========================= -->

    <!-- Main accent: warm orange -->
    <Color x:Key="Accent">#ED985F</Color>

    <!-- Soft accent for highlights, chips, subtle fills -->
    <Color x:Key="AccentSoft">#F7B980</Color>


    <!-- ========================= -->
    <!-- UI elements -->
    <!-- ========================= -->

    <!-- Borders & dividers -->
    <Color x:Key="BorderColor">#E0E0E0</Color>
    <Color x:Key="DividerColor">#D6D6D6</Color>


    <!-- ========================= -->
    <!-- Buttons -->
    <!-- ========================= -->

    <!-- Primary button -->
    <Color x:Key="ButtonPrimaryBackground">#ED985F</Color>
    <Color x:Key="ButtonPrimaryText">#001F3D</Color>

    <!-- Secondary button -->
    <Color x:Key="ButtonSecondaryBackground">#FFFFFF</Color>
    <Color x:Key="ButtonSecondaryText">#ED985F</Color>


    <!-- ========================= -->
    <!-- States -->
    <!-- ========================= -->

    <Color x:Key="DisabledBackground">#E6E6E6</Color>
    <Color x:Key="DisabledText">#9CA3AF</Color>


    <!-- ========================= -->
    <!-- Accessibility -->
    <!-- ========================= -->

    <!-- Used for high-contrast touch overlays -->
    <Color x:Key="accElementBackground">Transparent</Color>


    <!-- ========================= -->
    <!-- Debug flag -->
    <!-- ========================= -->

    <x:String x:Key="__ColorsDefaultLoaded">YES</x:String>

</ResourceDictionary>